DATABASE_URL=postgres://atrium:atrium@localhost:5432/atrium?sslmode=disable
MIGRATIONS_DIR=backend/migrations
PROVISIONING_PATH=backend/configs/provisioning.yaml
PROVISIONING_ARCHIVE_MISSING=1
FAMILY_NOTE_PATH=./data/family_note.md
WIDGETS_CONFIG_PATH=./data/widgets.yaml

AUTH_DISABLED=1
OIDC_ISSUER=
OIDC_CLIENT_ID=
