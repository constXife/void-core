AUTH_ADMIN_EMAILS=admin@example.com
AUTH_DEFAULT_ROLE=user
AUTH_ROLE_MAP=
AUTH_GUEST_ENABLED=1
AUTH_COOKIE_SECRET=replace-with-long-random-string
